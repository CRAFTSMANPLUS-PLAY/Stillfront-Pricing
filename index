<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>CRAFTSMAN+ — Stillfront Pricing</title>
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  :root {
    --orange: #FA6C00; --yellow: #FEC01F; --black: #090909;
    --white: #FDFDFD; --mid: #888; --surface: #141414;
    --surface2: #1c1c1c; --border: #2a2a2a; --green: #5aad3a;
  }
  html, body { background: var(--black); color: var(--white); font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Arial, sans-serif; min-height: 100vh; -webkit-font-smoothing: antialiased; }
  nav { position: sticky; top: 0; z-index: 100; background: var(--black); border-bottom: 1px solid var(--border); display: flex; align-items: center; justify-content: space-between; padding: 0 2rem; height: 56px; }
  .nav-logo { display: flex; align-items: center; gap: 10px; text-decoration: none; }
  
  
  .nav-right { display: flex; align-items: center; gap: 20px; }
  .nav-tag { font-size: 10px; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: var(--mid); }
  .nav-pill { font-size: 11px; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; color: var(--black); background: var(--orange); padding: 6px 14px; border-radius: 100px; white-space: nowrap; }
  
  
  .hero { padding: 3.5rem 2rem 1.5rem; max-width: 860px; margin: 0 auto; }
  .hero-eyebrow { font-size: 10px; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: var(--orange); margin-bottom: 1rem; }
  .hero-title { font-size: clamp(2rem, 5vw, 3rem); font-weight: 800; line-height: 1.08; letter-spacing: -0.03em; color: var(--white); margin-bottom: 0.75rem; }
  .hero-title span { color: var(--orange); }
  .hero-sub { font-size: 14px; color: var(--mid); line-height: 1.6; }
  .content { max-width: 860px; margin: 0 auto; padding: 0 2rem 4rem; }
  .section-label { font-size: 9px; font-weight: 700; letter-spacing: 0.16em; text-transform: uppercase; color: var(--mid); margin-bottom: 14px; }
  .card { background: var(--surface); border: 1px solid var(--border); border-radius: 12px; padding: 1.5rem; margin-bottom: 1.25rem; }
  .card-accent { border-top: 2px solid var(--orange); }
  .stat-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 10px; margin-bottom: 1.5rem; }
  .stat-box { background: var(--surface2); border-radius: 8px; padding: 1rem; }
  .stat-lbl { font-size: 9px; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: var(--mid); margin-bottom: 6px; }
  .stat-num { font-size: 26px; font-weight: 800; letter-spacing: -0.03em; color: var(--white); }
  .stat-num.o { color: var(--orange); }
  .trow { display: flex; justify-content: space-between; align-items: center; padding: 10px 0; border-bottom: 1px solid var(--border); font-size: 13px; gap: 8px; }
  .trow:last-child { border-bottom: none; }
  .trow .lbl { color: var(--mid); flex: 1; }
  .trow .mid-txt { font-size: 11px; color: #555; white-space: nowrap; }
  .trow .val { font-weight: 600; color: var(--white); white-space: nowrap; }
  .trow .val.o { color: var(--orange); }
  .trow .val.g { color: var(--green); }
  .trow.active { background: rgba(250,108,0,0.08); border-radius: 6px; padding: 10px 10px; margin: 0 -10px; }
  .trow.active .val { color: var(--orange); }
  hr { border: none; border-top: 1px solid var(--border); margin: 1.75rem 0; }
  .slider-row { display: flex; align-items: center; gap: 16px; margin-bottom: 1.25rem; }
  .slider-side { font-size: 12px; color: var(--mid); white-space: nowrap; min-width: 44px; }
  .slider-val { font-size: 16px; font-weight: 800; color: var(--orange); min-width: 100px; text-align: right; letter-spacing: -0.02em; }
  input[type=range] { flex: 1; -webkit-appearance: none; appearance: none; height: 3px; border-radius: 2px; background: var(--border); outline: none; cursor: pointer; }
  input[type=range]::-webkit-slider-thumb { -webkit-appearance: none; width: 22px; height: 22px; border-radius: 50%; background: var(--orange); cursor: pointer; border: 3px solid var(--black); box-shadow: 0 0 0 1.5px var(--orange); }
  input[type=range]::-moz-range-thumb { width: 22px; height: 22px; border-radius: 50%; background: var(--orange); cursor: pointer; border: 3px solid var(--black); }
  .result-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 10px; margin-bottom: 1.25rem; }
  .result-card { background: var(--surface2); border: 1px solid var(--border); border-radius: 8px; padding: 1rem 1.25rem; }
  .result-card.hl { border: 1.5px solid var(--orange); background: rgba(250,108,0,0.06); }
  .result-lbl { font-size: 9px; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: var(--mid); margin-bottom: 8px; }
  .result-num { font-size: 22px; font-weight: 800; letter-spacing: -0.03em; color: var(--white); }
  .result-num.o { color: var(--orange); }
  .result-num.g { color: var(--green); }
  .result-sub { font-size: 11px; color: var(--mid); margin-top: 4px; }
  .bar-track { height: 4px; border-radius: 2px; background: var(--border); margin: 1rem 0 6px; overflow: hidden; }
  .bar-fill { height: 100%; border-radius: 2px; background: var(--green); transition: width 0.2s ease; }
  .bar-labels { display: flex; justify-content: space-between; font-size: 10px; color: var(--mid); }
  .bar-labels .mid { font-weight: 700; color: var(--green); }
  .slider-note { font-size: 11px; color: var(--mid); font-style: italic; margin-top: 1rem; min-height: 15px; }
  .note { font-size: 11px; color: #555; line-height: 1.6; margin-top: 1rem; }
  footer { border-top: 1px solid var(--border); padding: 1.5rem 2rem; display: flex; justify-content: space-between; align-items: center; font-size: 11px; color: var(--mid); }
  footer a { color: var(--orange); text-decoration: none; }
  @media (max-width: 580px) {
    nav { padding: 0 1rem; } .hero, .content { padding-left: 1rem; padding-right: 1rem; }
    .stat-grid, .result-grid { grid-template-columns: 1fr 1fr; }
    .stat-grid .stat-box:last-child, .result-grid .result-card:last-child { grid-column: 1 / -1; }
    .nav-tag { display: none; }
  }
</style>
</head>
<body>

<nav>
  <a class="nav-logo" href="#">
    <img src="data:image/png;base64," alt="CRAFTSMAN+" style="height:22px;width:auto;display:block;">
  </a>
  <div class="nav-right">
    <span class="nav-tag">Stillfront Group &nbsp;·&nbsp; Renewal 2026</span>
    <span class="nav-pill">Pricing</span>
  </div>
</nav>



<div class="hero">
  <p class="hero-eyebrow">Pricing Calculator</p>
  <h1 class="hero-title">Find the right<br><span>seat structure.</span></h1>
  <p class="hero-sub">See what you're paying today vs. what a right-sized deal looks like. Drag to explore.</p>
</div>

<div class="content">
  <p class="section-label">Current deal — what you're paying</p>
  <div class="card card-accent">
    <div class="stat-grid">
      <div class="stat-box"><div class="stat-lbl">Annual contract</div><div class="stat-num o">$144,000</div></div>
      <div class="stat-box"><div class="stat-lbl">Seat structure</div><div class="stat-num">Unlimited</div></div>
      <div class="stat-box"><div class="stat-lbl">Monthly rate</div><div class="stat-num">$12,000</div></div>
    </div>
    <p class="section-label">Effective cost per seat — at $144k annual</p>
    <div class="trow"><span class="lbl">Using 5 seats</span><span class="val">$28,800 / seat / yr</span></div>
    <div class="trow"><span class="lbl">Using 10 seats</span><span class="val">$14,400 / seat / yr</span></div>
    <div class="trow"><span class="lbl">Using 15 seats (target)</span><span class="val o">$9,600 / seat / yr</span></div>
    <div class="trow"><span class="lbl">Using 20 seats</span><span class="val">$7,200 / seat / yr</span></div>
    <div class="trow"><span class="lbl">Using 30 seats</span><span class="val g">$4,800 / seat / yr</span></div>
    <p class="note">The more teams that use PLAY under the unlimited deal, the lower the effective cost per seat — with zero additional spend. Every new user added costs $0 extra.</p>
  </div>

  <hr>

  <p class="section-label">Build your package — drag to explore</p>
  <div class="card">
    <div class="slider-row">
      <span class="slider-side">Seats</span>
      <input type="range" min="1" max="11" step="1" value="10" id="seat-slider">
      <span class="slider-val" id="seat-label">10 seats</span>
    </div>
    <div class="result-grid">
      <div class="result-card hl">
        <div class="result-lbl">Monthly cost</div>
        <div class="result-num o" id="monthly-cost">$10,250</div>
        <div class="result-sub" id="monthly-sub">10 seats</div>
      </div>
      <div class="result-card">
        <div class="result-lbl">Annual total</div>
        <div class="result-num" id="annual-cost">$123,000</div>
        <div class="result-sub" id="annual-sub">vs. $144k current</div>
      </div>
      <div class="result-card">
        <div class="result-lbl">Cost per seat / yr</div>
        <div class="result-num g" id="cps-result">$12,300</div>
        <div class="result-sub" id="cps-sub">$1,025 / seat / mo</div>
      </div>
    </div>
    <div class="bar-track"><div class="bar-fill" id="savings-fill" style="width:54%;"></div></div>
    <div class="bar-labels">
      <span>$0 saved</span>
      <span class="mid" id="savings-label">Saving $21,000/yr vs. current</span>
      <span>$39k saved</span>
    </div>
    <p class="slider-note" id="slider-note">Option A — Recommended. Covers the art hub + buffer. Full AI suite included.</p>
  </div>

  <p class="section-label">Full pricing reference</p>
  <div class="card">
    <div id="pricing-table"></div>
  </div>
</div>

<footer>
  <span>© 2026 CRAFTSMAN+ &nbsp;·&nbsp; Stillfront Group Renewal</span>
  <a href="mailto:shane.hedengran@craftsmanplus.com">shane.hedengran@craftsmanplus.com</a>
</footer>

<script>
  var PRICING = [
    {seats:1,monthly:2500,label:'1 seat'},{seats:2,monthly:3500,label:'2 seats'},
    {seats:3,monthly:4500,label:'3 seats'},{seats:4,monthly:5500,label:'4 seats'},
    {seats:5,monthly:6500,label:'5 seats'},{seats:6,monthly:7250,label:'6 seats'},
    {seats:7,monthly:8000,label:'7 seats'},{seats:8,monthly:8750,label:'8 seats'},
    {seats:9,monthly:9500,label:'9 seats'},{seats:10,monthly:10250,label:'10 seats'},
    {seats:999,monthly:12000,label:'Unlimited'},
  ];
  var NOTES = ['','','','',
    'Minimum viable — small focused team only.',
    'Lean option. Covers core power users.',
    'Lean option B. Good fit for art hub core.',
    'Option B — 8 seats. Saves $39k/yr vs. current.',
    '',
    'Option A — Recommended. Art hub + headroom. Saves $21k/yr.',
    'Current structure. Maximum group-wide flexibility.',
  ];
  var CURRENT = 144000;
  function fmt(n){return '$'+Math.round(n).toLocaleString();}
  var tableEl = document.getElementById('pricing-table');
  var rows = [];
  PRICING.forEach(function(tier,i){
    var annual=tier.monthly*12, seatsNum=tier.seats===999?30:tier.seats, cps=Math.round(annual/seatsNum);
    var row=document.createElement('div'); row.className='trow';
    row.innerHTML='<span class="lbl">'+tier.label+'</span><span class="mid-txt">'+fmt(tier.monthly)+'/mo &nbsp;·&nbsp; '+fmt(annual)+'/yr</span><span class="val">'+fmt(cps)+'/seat/yr</span>';
    tableEl.appendChild(row); rows.push(row);
  });
  function update(){
    var idx=parseInt(document.getElementById('seat-slider').value)-1;
    var tier=PRICING[idx], monthly=tier.monthly, annual=monthly*12;
    var seatsNum=tier.seats===999?30:tier.seats;
    var cpsMonthly=monthly/seatsNum, cpsAnnual=annual/seatsNum;
    var saving=CURRENT-annual, maxSave=CURRENT-(PRICING[7].monthly*12);
    var savePct=Math.max(0,Math.min(100,(saving/maxSave)*100));
    document.getElementById('seat-label').textContent=tier.label;
    document.getElementById('monthly-cost').textContent=fmt(monthly)+'/mo';
    document.getElementById('monthly-sub').textContent=tier.label;
    document.getElementById('annual-cost').textContent=fmt(annual)+'/yr';
    document.getElementById('annual-sub').textContent=saving>0?'Saves '+fmt(saving)+' vs. current':'Same as current';
    document.getElementById('cps-result').textContent=(tier.seats===999?'~':'')+fmt(cpsAnnual);
    document.getElementById('cps-sub').textContent=(tier.seats===999?'~':'')+fmt(cpsMonthly)+' / seat / mo';
    document.getElementById('savings-fill').style.width=Math.max(0,savePct)+'%';
    document.getElementById('savings-label').textContent=saving>0?'Saving '+fmt(saving)+'/yr vs. current':'No change from current';
    document.getElementById('slider-note').textContent=NOTES[idx]||'';
    rows.forEach(function(r,i){r.classList.toggle('active',i===idx);});
  }
  document.getElementById('seat-slider').addEventListener('input',update);
  update();
</script>
</body>
</html>
